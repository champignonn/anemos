APP_NAME="TSV-Pulse"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Paris
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tsv_pulse
DB_USERNAME=root
DB_PASSWORD=chef

SESSION_DRIVER=database
SESSION_LIFETIME=120

# Configuration Strava (OPTIONNEL)
# Obtenez vos clés sur : https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI="${APP_URL}/strava/callback"
